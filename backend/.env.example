# ─── BingX API ────────────────────────────────────────────────────────────────
# Demo (VST)
BINGX_BASE_URL=https://open-api-vst.bingx.com
# Production (uncomment when ready)
# BINGX_BASE_URL=https://open-api.bingx.com

BINGX_API_KEY=your_api_key_here
BINGX_API_SECRET=your_api_secret_here

# ─── WebSocket ────────────────────────────────────────────────────────────────
# Demo
BINGX_WS_URL=wss://open-api-ws.bingx.com/market
# The VST env shares the same WS endpoint

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_authorized_chat_id
